# Ignore Python build artifacts
__pycache__/
*.pyc
*.pyo
*.pyd

# Ignore editor and OS temporary files
*.DS_Store
*.swp
*.swo
*.bak
*.log
*.tmp

# Ignore data and large archives
*.nii
*.npz
*.nc
*.h5
*.hdf5
*.csv
*.mat
*.tar
*.gz
*.zip
*.7z
*.tar.gz
*.tgz
*.bz2
*.xz
*.dat
*.dbf

# Ignore shell scripts only if not needed for repository
# Uncomment the next line if you do not want to track .sh files
# *.sh

# Ignore some large data-only directories
mod06/
myd06/
processed_data/

# Keep source directories with Python scripts
